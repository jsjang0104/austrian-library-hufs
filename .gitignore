# 1. 환경 변수 및 비밀 정보 (Secrets)
####################################
# 모든 .env 파일 (루트 포함)
.env
backend/.env
# .env.local 등 로컬 전용 설정 파일
*.local
# Django 로컬 설정 파일
settings_local.py

# 데이터베이스 파일
db.sqlite3
backend/dq.sqlite3

# 검색 인덱스 등 DB로부터 재생성 가능한 산출물
backend/media/*
!backend/media/search_index/
backend/media/search_index/*
!backend/media/search_index/books.faiss

## 2. 로그 및 임시 파일
#####################
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*
lerna-debug.log*
# Django 백엔드 로그 폴더
backend/logs/

## 3. 의존성 및 빌드 결과물 (Node.js/Vite)
##########################
# 루트 node_modules
node_modules/
# 루트 dist 폴더 (Vite 빌드 결과물)
dist/
# SSR(Server-Side Rendering) 빌드 결과물
dist-ssr/

# 프론트엔드 폴더 내의 의존성 및 빌드 결과물
frontend/node_modules/
frontend/dist/

## 4. Python/Django
###################
# 가상 환경
venv/
.venv/
backend_env/

# 캐시 및 컴파일 파일
__pycache__/
backend/__pycache__/
*.pyc
*.mo

## 5. IDE 및 OS 파일
####################
# IDE/에디터 설정 폴더
# JetBrains (PyCharm 등)
.idea/
# VS Code 설정
.vscode/
!.vscode/extensions.json    # 확장 프로그램 추천 파일만 예외적으로 추적

# OS/기타 파일
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?